<Page
    x:Class="MDEdit.WinUI.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Dark"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    mc:Ignorable="d">

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="New Tab" Command="{x:Bind ViewModel.NewTabCommand}" />
                <MenuFlyoutItem Text="Open Markdown..." Command="{x:Bind ViewModel.OpenCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Save" Command="{x:Bind ViewModel.SaveCommand}" />
                <MenuFlyoutItem Text="Save As..." Command="{x:Bind ViewModel.SaveAsCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Close Tab" Command="{x:Bind ViewModel.CloseTabCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Exit" Command="{x:Bind ViewModel.ExitCommand}" />
            </MenuBarItem>
            <MenuBarItem Title="Edit">
                <MenuFlyoutItem Text="Format Markdown" Command="{x:Bind ViewModel.FormatCommand}" />
            </MenuBarItem>
            <MenuBarItem Title="View">
                <MenuFlyoutItem Text="Toggle Preview" Command="{x:Bind ViewModel.TogglePreviewCommand}" />
            </MenuBarItem>
        </MenuBar>

        <CommandBar Grid.Row="1" DefaultLabelPosition="Right" Background="Transparent">
            <AppBarButton Icon="Add" Label="New" Command="{x:Bind ViewModel.NewTabCommand}" />
            <AppBarButton Icon="OpenFile" Label="Open" Command="{x:Bind ViewModel.OpenCommand}" />
            <AppBarButton Icon="Save" Label="Save" Command="{x:Bind ViewModel.SaveCommand}" />
            <AppBarButton Icon="SaveLocal" Label="Save As" Command="{x:Bind ViewModel.SaveAsCommand}" />
            <AppBarSeparator />
            <AppBarButton Icon="Edit" Label="Format" Command="{x:Bind ViewModel.FormatCommand}" />
            <AppBarButton Icon="Preview" Label="Preview" Command="{x:Bind ViewModel.TogglePreviewCommand}" />
        </CommandBar>

        <TabView
            x:Name="DocumentTabs"
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AddTabButtonClick="DocumentTabs_AddTabButtonClick"
            SelectionChanged="DocumentTabs_SelectionChanged"
            TabCloseRequested="DocumentTabs_TabCloseRequested" />
    </Grid>
</Page>
