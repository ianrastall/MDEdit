<Page
    x:Class="MDEdit.WinUI.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Dark"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    mc:Ignorable="d">

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="New Tab" Command="{x:Bind ViewModel.NewTabCommand}" />
                <MenuFlyoutItem Text="Open Markdown..." Command="{x:Bind ViewModel.OpenCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Save" Command="{x:Bind ViewModel.SaveCommand}" />
                <MenuFlyoutItem Text="Save As..." Command="{x:Bind ViewModel.SaveAsCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Close Tab" Command="{x:Bind ViewModel.CloseTabCommand}" />
                <MenuFlyoutItem Text="Close All Saved" Command="{x:Bind ViewModel.CloseAllSavedCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Exit" Command="{x:Bind ViewModel.ExitCommand}" />
            </MenuBarItem>
            <MenuBarItem Title="Edit">
                <MenuFlyoutItem Text="Copy All" Click="CopyAll_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Append to End..." Click="AppendToEnd_Click" />
                <MenuFlyoutItem Text="Append at Cursor..." Click="AppendAtCursor_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Format Markdown" Command="{x:Bind ViewModel.FormatCommand}" />
            </MenuBarItem>
            <MenuBarItem Title="Structure">
                <MenuFlyoutItem x:Name="NumberHeadingsMenuItem" Text="Number Headings" Click="NumberHeadings_Click" />
                <MenuFlyoutItem x:Name="RemoveHeadingNumbersMenuItem" Text="Remove Heading Numbers" Click="RemoveHeadingNumbers_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="PromoteHeadingMenuItem" Text="Promote Heading" Click="PromoteHeading_Click" />
                <MenuFlyoutItem x:Name="DemoteHeadingMenuItem" Text="Demote Heading" Click="DemoteHeading_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="PromoteSubtreeMenuItem" Text="Promote Subtree" Click="PromoteSubtree_Click" />
                <MenuFlyoutItem x:Name="DemoteSubtreeMenuItem" Text="Demote Subtree" Click="DemoteSubtree_Click" />
            </MenuBarItem>
            <MenuBarItem Title="View">
                <MenuFlyoutItem Text="Heading Outline" Click="HeadingOutline_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Toggle Preview" Command="{x:Bind ViewModel.TogglePreviewCommand}" />
            </MenuBarItem>
        </MenuBar>

        <CommandBar Grid.Row="1" DefaultLabelPosition="Right" Background="Transparent">
            <AppBarButton Icon="Add" Label="New" Command="{x:Bind ViewModel.NewTabCommand}" />
            <AppBarButton Icon="OpenFile" Label="Open" Command="{x:Bind ViewModel.OpenCommand}" />
            <AppBarButton Icon="Save" Label="Save" Command="{x:Bind ViewModel.SaveCommand}" />
            <AppBarButton Icon="SaveLocal" Label="Save As" Command="{x:Bind ViewModel.SaveAsCommand}" />
            <AppBarButton Icon="Cancel" Label="Close Saved" Command="{x:Bind ViewModel.CloseAllSavedCommand}" />
            <AppBarSeparator />
            <AppBarButton Icon="Copy" Label="Copy All" Click="CopyAll_Click" />
            <AppBarButton Label="Append End" Click="AppendToEnd_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE710;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Append Cursor" Click="AppendAtCursor_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8A5;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton Icon="Edit" Label="Format" Command="{x:Bind ViewModel.FormatCommand}" />
            <AppBarButton Label="Outline" Click="HeadingOutline_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8FD;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Icon="Preview" Label="Preview" Command="{x:Bind ViewModel.TogglePreviewCommand}" />
        </CommandBar>

        <CommandBar Grid.Row="2" DefaultLabelPosition="Right" Background="Transparent">
            <AppBarButton x:Name="NumberHeadingsButton" Label="Number" Click="NumberHeadings_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8FD;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="RemoveHeadingNumbersButton" Label="Unnumber" Click="RemoveHeadingNumbers_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE74D;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton x:Name="PromoteHeadingButton" Label="Promote" Click="PromoteHeading_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE70E;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="DemoteHeadingButton" Label="Demote" Click="DemoteHeading_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE70D;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton x:Name="PromoteSubtreeButton" Label="Promote Tree" Click="PromoteSubtree_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE74A;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="DemoteSubtreeButton" Label="Demote Tree" Click="DemoteSubtree_Click">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE74B;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <TabView
            x:Name="DocumentTabs"
            Grid.Row="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AddTabButtonClick="DocumentTabs_AddTabButtonClick"
            SelectionChanged="DocumentTabs_SelectionChanged"
            TabCloseRequested="DocumentTabs_TabCloseRequested" />
    </Grid>
</Page>
